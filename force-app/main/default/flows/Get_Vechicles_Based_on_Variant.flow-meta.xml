<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Get Vechicles Based on Variant</description>
    <environments>Default</environments>
    <interviewLabel>Get Vechicles Based on Variant {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Get Vechicles Based on Variant</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get Vehicles Definitions</description>
        <name>Get_Vehicles_Definitions</name>
        <label>Get Vehicles Definitions</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <filterLogic>(Door_Count__c = {!DoorCount} OR {!DoorCount} Is Null = TRUE) AND  (Body_Type__c = {!BodyType} OR {!BodyType} Is Null = TRUE) AND (Battery_Type__c = {!BatteryType} OR {!BatteryType} Is Null = TRUE) AND (Engine_Capacity__c = {!EngineCapacity} OR {!EngineCapacity} Is Null = TRUE)</filterLogic>
        <filters>
            <field>null__NotFound</field>
            <operator>EqualTo</operator>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>VehicleDefinition</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Vehicles_Definitions</targetReference>
        </connector>
    </start>
    <status>InvalidDraft</status>
    <variables>
        <name>bodyType</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>doorCount</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <scale>2</scale>
    </variables>
</Flow>
